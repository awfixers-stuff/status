# ============================================================================
# Railway Environment Configuration (Example)
# ============================================================================
# Copy this file to .env.railway and replace with your actual values
# These variables should be set in the Railway dashboard under Variables
# https://docs.railway.app/environment-variables

# DATABASE
# ============================================================================
# Turso database connection URL (from Turso dashboard)
# Format: libsql://database-name-account-uuid.turso.io
DATABASE_URL=libsql://your-database-name-account-uuid.turso.io

# Turso auth token (from Turso dashboard)
DATABASE_AUTH_TOKEN=your-turso-auth-token

# Alternative: Use Railway's built-in PostgreSQL database
# DATABASE_URL=$DATABASE_URL  # Railway auto-sets this for PostgreSQL

# PUBLIC DOMAINS (set these in Railway per service)
# ============================================================================
# RAILWAY_PUBLIC_DOMAIN=your-dashboard-domain.up.railway.app
# STATUS_PAGE_PUBLIC_DOMAIN=your-status-page-domain.up.railway.app

# AUTHENTICATION
# ============================================================================
# [REQUIRED] NextAuth secret - generate with: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here-min-32-chars

# [REQUIRED] Self-hosted mode - enables magic link authentication
SELF_HOST=true

# EMAIL
# ============================================================================
# [REQUIRED] Resend API key for sending magic link emails
# Get from: https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here

# REDIS & QUEUE (Optional)
# ============================================================================
# Upstash Redis for caching
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# QStash for background jobs
QSTASH_CURRENT_SIGNING_KEY=your-qstash-signing-key
QSTASH_NEXT_SIGNING_KEY=your-qstash-next-signing-key
QSTASH_TOKEN=your-qstash-token
QSTASH_URL=https://qstash.upstash.io/v1/publish/

# ANALYTICS (Optional)
# ============================================================================
# Tinybird for monitor analytics and charts
# Get from: https://www.tinybird.co
TINY_BIRD_API_KEY=your-tinybird-api-key

# API KEYS (Optional)
# ============================================================================
# Unkey for API key management
# Get from: https://unkey.dev
UNKEY_API_ID=your-unkey-api-id
UNKEY_TOKEN=your-unkey-token

# Super admin token for privileged operations
SUPER_ADMIN_TOKEN=your-super-admin-token

# SERVICE CONFIGURATION
# ============================================================================
NODE_ENV=production

# Server region identifier
FLY_REGION=railway

# GOOGLE CLOUD (Optional - for scheduled tasks)
# ============================================================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=your-gcp-location
GCP_CLIENT_EMAIL=your-gcp-client-email
GCP_PRIVATE_KEY=your-gcp-private-key

# Cron secret for scheduled jobs
CRON_SECRET=your-random-cron-secret

# STRIPE (Optional - for payments)
# ============================================================================
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET_KEY=whsec_your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key

# VERCEL (Optional - for custom domains)
# ============================================================================
PROJECT_ID_VERCEL=your-vercel-project-id
TEAM_ID_VERCEL=your-vercel-team-id
VERCEL_AUTH_BEARER_TOKEN=your-vercel-auth-token

# OBSERVABILITY (Optional)
# ============================================================================
# Sentry error tracking
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@o123456.ingest.sentry.io/1234567
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Slack webhook for notifications
SLACK_SUPPORT_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook

# DEVELOPMENT & TESTING
# ============================================================================
TURBO_ENV_MODE=loose
